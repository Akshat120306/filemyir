rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "akshatmaggon1@gmail.com";
    }

    function isOwner() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email != "akshatmaggon1@gmail.com"
        && resource.data.email == request.auth.token.email;
    }

    function isClientFor(clientId) {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email != "akshatmaggon1@gmail.com"
        && exists(/databases/$(database)/documents/clients/$(clientId))
        && get(/databases/$(database)/documents/clients/$(clientId)).data.email == request.auth.token.email;
    }

    // Leads — public create (from questionnaire), admin manages, lead owner can read their own
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
    }

    match /clients/{clientId} {
      allow read, write: if isAdmin();
      allow read: if isOwner();
      allow update: if isOwner()
        && !('status' in request.resource.data)
        && !('assignedTo' in request.resource.data)
        && !('feeAmount' in request.resource.data)
        && !('feeStatus' in request.resource.data);

      match /documents/{documentId} {
        allow read: if isAdmin() || isClientFor(clientId);
        allow create: if isAdmin() || isClientFor(clientId);
        allow update: if isAdmin();
        // Client can delete only their own uploads
        allow delete: if isAdmin() || (isClientFor(clientId) && resource.data.uploadedBy == 'client');
      }
      match /tasks/{taskId} {
        allow read: if isAdmin() || isClientFor(clientId);
        allow write: if isAdmin();
      }
      match /notes/{noteId} {
        allow read, create: if isAdmin();
        allow update, delete: if false;
      }
      match /messages/{messageId} {
        allow read: if isAdmin() || isClientFor(clientId);
        allow create: if isAdmin() || isClientFor(clientId);
        allow update, delete: if false;
      }
      match /payments/{paymentId} {
        allow read: if isAdmin() || isClientFor(clientId);
        allow create: if isAdmin() || isClientFor(clientId);
        allow update, delete: if isAdmin();
      }
      match /settings/{document} {
        allow read, write: if isAdmin();
      }
      match /statusHistory/{eventId} {
        allow read: if isAdmin() || isClientFor(clientId);
        allow create: if isAdmin();
        allow update, delete: if false;
      }
      match /returns/{returnId} {
        allow read: if isAdmin() || isClientFor(clientId);
        allow write: if isAdmin();
      }
    }

    // Payment settings — admin writes, any authenticated user can read (to show UPI ID on payment page)
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Assessments — public create (no login needed), admin reads all, user reads own by email
    match /assessments/{assessmentId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update: if isAdmin() || (request.auth != null && resource.data.leadInfo.email == request.auth.token.email);
    }

    // Notifications — authenticated users can create; owner can read and mark read
    match /notifications/{notifId} {
      allow create: if request.auth != null || true; // allow unauthenticated for lead notifications
      allow read, update: if request.auth != null
        && resource.data.recipientEmail == request.auth.token.email;
      allow read, write: if isAdmin();
    }
  }
}
